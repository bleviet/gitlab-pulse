# ────────────────────────────────────────────────────────────
# GitLab Pulse — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ────────────────────────────────────────────────────────────

# GitLab connection (required for live data sync)
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=your-personal-access-token

# Comma-separated GitLab project IDs to sync.
# Find your project ID under Settings → General in GitLab.
PROJECT_IDS=

# Dashboard admin password (optional, default: admin)
# ADMIN_PASSWORD=admin

# Ollama AI endpoint (optional, default: http://localhost:11434)
# OLLAMA_ENDPOINT=http://localhost:11434
